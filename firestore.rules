rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowedStudent(studentId) {
      return studentId in ["student-1", "student-2"];
    }

    match /students/{studentId}/{document=**} {
      allow read, write: if isAllowedStudent(studentId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
